{
  "name": "@visaproof/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for VisaProof — the on-chain Agent Visa qualification protocol on Celo. Report activity, compute tier, and discover high-tier agents in a few lines.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "celo",
    "agent",
    "visa",
    "erc-8004",
    "self-protocol",
    "ai-agents",
    "viem",
    "visaproof"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
