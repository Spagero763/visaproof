# Sample environment variables. Copy to .env and fill in.

# RPCs
CELO_RPC_URL=https://forno.celo.org
CELO_ALFAJORES_RPC_URL=https://alfajores-forno.celo-testnet.org

# Deployer key: do NOT put a raw private key here. Import it once into an
# encrypted keystore with
#   cast wallet import visaproof-deployer --interactive
# then deploy with --account visaproof-deployer. The key never touches a file
# in this repo.

# Celoscan API key for source verification
CELOSCAN_API_KEY=

# Protocol addresses are not read from env. The deploy script uses the verified
# values in script/CeloAddresses.sol.
